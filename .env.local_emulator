# Context configuration
CONTEXT=local_emulator

# Local emulator settings
PLATFORM_NAME=android
PLATFORM_VERSION=14.0
DEVICE_NAME=emulator-5554

# App path for local emulator (скачайте APK и положите в папку apps)
# Скачать APK можно отсюда: https://www.apkmirror.com/apk/wikipedia/wikipedia/
APP_PATH=./apps/wikipedia.apk

# Timeouts
TIMEOUT=45

# Browser management
HOLD_BROWSER_OPEN=false
SAVE_PAGE_SOURCE_ON_FAILURE=true