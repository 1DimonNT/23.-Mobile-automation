# Context configuration (local_emulator, local_real, bstack)
CONTEXT=local_emulator

# BrowserStack Credentials (for bstack context only)
BROWSERSTACK_USERNAME=your_username_here
BROWSERSTACK_ACCESS_KEY=your_access_key_here
REMOTE_URL=http://hub.browserstack.com/wd/hub

# Platform capabilities
PLATFORM_NAME=android
PLATFORM_VERSION=13.0
DEVICE_NAME=Samsung Galaxy S23 Ultra

# For local real device (USB connection)
UDID=your_device_udid

# App configuration
APP_PATH=./apps/wikipedia.apk
APP_URL=bs://your_browserstack_app_url

# Timeouts
TIMEOUT=45

# Browser management
HOLD_BROWSER_OPEN=false
SAVE_PAGE_SOURCE_ON_FAILURE=true

# Allure
ALLURE_RESULTS_DIR=allure-results