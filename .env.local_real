# Context configuration
CONTEXT=local_real

# Real device settings (подключен по USB)
PLATFORM_NAME=android
PLATFORM_VERSION=13.0
DEVICE_NAME=Samsung Galaxy S23 Ultra

# Real device UDID (узнайте через команду: adb devices)
UDID=your_device_udid_here

# App path for real device
APP_PATH=./apps/wikipedia.apk

# Timeouts
TIMEOUT=45

# Browser management
HOLD_BROWSER_OPEN=false
SAVE_PAGE_SOURCE_ON_FAILURE=true